model ClassroomSubjectAssessment {
  id                   Int                                  @unique @default(autoincrement())
  title                String
  obtainable           Float                                @default(0)
  percentageObtainable Float?                               @default(0)
  index                Float?
  isGroup              Boolean                              @default(false)
  parentAssessmentId   Int?
  printMode            ClassroomSubjectAssessmentPrintMode  @default(EXPANDED)

  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @updatedAt
  deletedAt DateTime? @db.Timestamp(0)

  assessmentResults   StudentAssessmentRecord[]
  departmentSubjectId String?
  departmentSubject   DepartmentSubject?           @relation(fields: [departmentSubjectId], references: [id])
  parentAssessment    ClassroomSubjectAssessment?  @relation("AssessmentHierarchy", fields: [parentAssessmentId], references: [id])
  childAssessments    ClassroomSubjectAssessment[] @relation("AssessmentHierarchy")
}

model StudentAssessmentRecord {
  id                       Int     @unique @default(autoincrement())
  obtained                 Float?
  percentageScore          Float?
  studentId                String?
  classSubjectAssessmentId Int?
  remarkOnAssementId       Int?
  studentTermFormId        String?

  createdAt DateTime? @default(now()) @db.Timestamp(0)
  updatedAt DateTime? @updatedAt
  deletedAt DateTime? @db.Timestamp(0)

  student                Students?                   @relation(fields: [studentId], references: [id])
  classSubjectAssessment ClassroomSubjectAssessment? @relation(fields: [classSubjectAssessmentId], references: [id])
  studentTermForm        StudentTermForm?            @relation(fields: [studentTermFormId], references: [id])

  @@unique([studentId, studentTermFormId, classSubjectAssessmentId])
}

model ReportPrintLog {
  id              String   @id @default(uuid())
  schoolProfileId String?
  termId          String?
  termFormIds     String[]
  departmentIds   String[]
  printedAt       DateTime @default(now()) @db.Timestamp(0)
  createdAt       DateTime @default(now()) @db.Timestamp(0)

  schoolProfile SchoolProfile? @relation(fields: [schoolProfileId], references: [id])
  sessionTerm   SessionTerm?   @relation(fields: [termId], references: [id])
}

model AssessmentPublicLink {
  id                           String                     @id @default(uuid())
  status                       AssessmentPublicLinkStatus @default(PENDING)
  tokenHash                    String?                    @unique
  requestedDurationHours       Int                        @default(24)
  selectedDepartmentSubjectIds String[]                   @default([])
  selectedStudentTermFormIds   String[]                   @default([])
  reason                       String?
  rejectionNote                String?
  requesterUserId              String?
  requesterName                String?
  requesterEmail               String?
  createdByUserId              String?
  createdByName                String?
  approvedByUserId             String?
  approvedByName               String?
  rejectedByUserId             String?
  rejectedByName               String?
  revokedByUserId              String?
  revokedByName                String?
  approvedAt                   DateTime?                  @db.Timestamp(0)
  rejectedAt                   DateTime?                  @db.Timestamp(0)
  revokedAt                    DateTime?                  @db.Timestamp(0)
  expiresAt                    DateTime?                  @db.Timestamp(0)
  lastUsedAt                   DateTime?                  @db.Timestamp(0)
  createdAt                    DateTime?                  @default(now()) @db.Timestamp(0)
  updatedAt                    DateTime?                  @updatedAt
  deletedAt                    DateTime?                  @db.Timestamp(0)

  schoolProfileId       String
  schoolProfile         SchoolProfile       @relation(fields: [schoolProfileId], references: [id], onDelete: Cascade)
  sessionTermId         String
  sessionTerm           SessionTerm         @relation(fields: [sessionTermId], references: [id], onDelete: Cascade)
  classRoomDepartmentId String
  classRoomDepartment   ClassRoomDepartment @relation(fields: [classRoomDepartmentId], references: [id], onDelete: Cascade)

  @@index([schoolProfileId, status])
  @@index([schoolProfileId, sessionTermId, classRoomDepartmentId], map: "AssessmentPublicLink_schoolProfileId_sessionTermId_classRoo_idx")
  @@index([requesterUserId])
}

enum AssessmentPublicLinkStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  REVOKED
}

enum ClassroomSubjectAssessmentPrintMode {
  EXPANDED
  TOTAL
}

model AssessmentWorkbookExport {
  id                    String    @id @default(uuid())
  schoolProfileId       String
  sessionTermId         String
  classRoomDepartmentId String
  schemaVersion         Int       @default(1)
  createdByUserId       String?
  createdByName         String?
  createdAt             DateTime  @default(now()) @db.Timestamp(0)
  revokedAt             DateTime? @db.Timestamp(0)

  imports AssessmentWorkbookImport[]

  @@index([schoolProfileId, sessionTermId, classRoomDepartmentId])
}

model AssessmentWorkbookImport {
  id                    String   @id @default(uuid())
  exportId              String
  schoolProfileId       String
  sessionTermId         String
  classRoomDepartmentId String
  idempotencyKey        String
  fileDigest            String
  summary               Json
  createdAssessmentIds  Int[]    @default([])
  createdByUserId       String?
  createdByName         String?
  appliedAt             DateTime @default(now()) @db.Timestamp(0)
  createdAt             DateTime @default(now()) @db.Timestamp(0)
  updatedAt             DateTime @updatedAt

  export AssessmentWorkbookExport @relation(fields: [exportId], references: [id], onDelete: Restrict)

  @@unique([schoolProfileId, idempotencyKey])
  @@index([schoolProfileId, sessionTermId, classRoomDepartmentId])
  @@index([exportId])
}
