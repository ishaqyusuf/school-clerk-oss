{
  "name": "@school-clerk/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "rm -rf .cache dist tsc",
    "clean": "rm -rf .turbo node_modules",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "./with-env.sh bunx prisma generate",
    "db-migrate": "./with-env.sh bunx prisma migrate dev",
    "prisma-generate": "./with-env.sh bunx prisma generate",
    "push": "bunx env-cmd -f .env.production prisma db push",
    "pull": "./with-env.sh bunx prisma db pull",
    "studio": "./with-env.sh bunx prisma studio --port 5556",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@t3-oss/env-core": "^0.11.1",
    "date-fns": "^4.1.0",
    "react": "^19.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "prisma": "^6.18.0"
  }
}
