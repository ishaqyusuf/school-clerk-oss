{
  "name": "@school-clerk/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "rm -rf .cache dist tsc",
    "clean": "rm -rf .turbo node_modules",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "./with-env.sh bunx --bun prisma generate",
    "db:generate:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx --bun prisma generate",
    "db:generate:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx --bun prisma generate",
    "db-migrate": "./with-env.sh bunx --bun prisma migrate dev",
    "db-migrate:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx --bun prisma migrate dev",
    "db-migrate:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx --bun prisma migrate dev",
    "prisma-generate": "./with-env.sh bunx --bun prisma generate",
    "prisma-generate:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx --bun prisma generate",
    "prisma-generate:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx --bun prisma generate",
    "push": "bun run push:prod",
    "push:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx prisma db push",
    "push:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx prisma db push",
    "push:prod": "../../scripts/with-root-env.sh --mode production bunx prisma db push",
    "pull": "./with-env.sh bunx prisma db pull",
    "pull:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx prisma db pull",
    "pull:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx prisma db pull",
    "sync:prod-to-local": "bun scripts/sync-prod-to-local.ts",
    "sync:prod-to-local:dry-run": "bun scripts/sync-prod-to-local.ts --dry-run",
    "sync:prod-to-local:table": "bun scripts/sync-prod-to-local.ts --table",
    "studio": "./with-env.sh bunx prisma studio --port 5556",
    "studio:dev": "SCHOOL_CLERK_DB_MODE=remote-dev ./with-env.sh bunx prisma studio --port 5556",
    "studio:local": "SCHOOL_CLERK_DB_MODE=local ./with-env.sh bunx prisma studio --port 5556",
    "with-env": "bun ../../scripts/with-dev-infra.ts --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@t3-oss/env-core": "^0.11.1",
    "date-fns": "^4.1.0",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@school-clerk/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2"
  }
}
