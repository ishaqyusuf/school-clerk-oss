{
  "name": "@school-clerk/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "rm -rf .cache dist tsc",
    "clean": "rm -rf .turbo node_modules",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "bun ../../scripts/db-command.ts generate",
    "db:generate:dev": "bun ../../scripts/db-command.ts generate --remote",
    "db:generate:local": "bun ../../scripts/db-command.ts generate --local",
    "db:generate:prod": "bun ../../scripts/db-command.ts generate --prod",
    "db-migrate": "bun ../../scripts/db-command.ts migrate",
    "db-migrate:dev": "bun ../../scripts/db-command.ts migrate --remote",
    "db-migrate:local": "bun ../../scripts/db-command.ts migrate --local",
    "db-migrate:prod": "bun ../../scripts/db-command.ts migrate --prod",
    "prisma-generate": "bun ../../scripts/db-command.ts generate",
    "prisma-generate:dev": "bun ../../scripts/db-command.ts generate --remote",
    "prisma-generate:local": "bun ../../scripts/db-command.ts generate --local",
    "prisma-generate:prod": "bun ../../scripts/db-command.ts generate --prod",
    "push": "bun ../../scripts/db-command.ts push",
    "push:dev": "bun ../../scripts/db-command.ts push --remote",
    "push:local": "bun ../../scripts/db-command.ts push --local",
    "push:prod": "bun ../../scripts/db-command.ts push --prod",
    "pull": "bun ../../scripts/db-command.ts pull",
    "pull:dev": "bun ../../scripts/db-command.ts pull --remote",
    "pull:local": "bun ../../scripts/db-command.ts pull --local",
    "sync:prod-to-local": "bun scripts/sync-prod-to-local.ts",
    "sync:prod-to-local:dry-run": "bun scripts/sync-prod-to-local.ts --dry-run",
    "sync:prod-to-local:table": "bun scripts/sync-prod-to-local.ts --table",
    "studio": "bun ../../scripts/db-command.ts studio",
    "studio:dev": "bun ../../scripts/db-command.ts studio --remote",
    "studio:local": "bun ../../scripts/db-command.ts studio --local",
    "with-env": "bun ../../scripts/with-dev-infra.ts --"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "@t3-oss/env-core": "^0.11.1",
    "date-fns": "^4.1.0",
    "pg": "^8.22.0",
    "react": "^19.2.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@school-clerk/tsconfig": "workspace:*",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "typescript": "^5.9.2"
  }
}
