{
  "name": "@school-clerk/jobs",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run prisma.ts && bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode local -- node node_modules/trigger.dev/dist/esm/index.js dev --skip-update-check --skip-mcp-install --skip-rules-install --skip-platform-notifications",
    "deploy": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode prod -- sh -c 'bun run prisma.ts && node node_modules/trigger.dev/dist/esm/index.js deploy'",
    "typecheck": "tsc --noEmit",
    "with-env": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode local --",
    "with-env:prod": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode prod --"
  },
  "exports": {
    "./schema": "./src/schema.ts"
  },
  "dependencies": {
    "@fast-csv/format": "5.0.2",
    "@school-clerk/db": "workspace:*",
    "@school-clerk/email": "workspace:*",
    "@school-clerk/utils": "workspace:*",
    "@trigger.dev/sdk": "^4.0.0",
    "@sindresorhus/slugify": "^2.2.1",
    "@zip.js/zip.js": "^2.7.62",
    "camelcase-keys": "^9.1.3",
    "heic-convert": "1.2.4",
    "nanoid": "^5.1.5",
    "node-xlsx": "^0.24.0",
    "@prisma/client": "^6.11.1",
    "@prisma/instrumentation": "^6.11.1",
    "react": "^19.2.0",
    "resend": "^4.5.1",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@school-clerk/tsconfig": "workspace:*",
    "@trigger.dev/build": "^4.0.0",
    "trigger.dev": "^4.0.0",
    "@types/react": "^19.2.2",
    "@types/heic-convert": "2.1.0"
  }
}
