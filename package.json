{
  "name": "schoolclerk",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "./scripts/with-root-env.sh --mode production turbo build",
    "build:dashboard": "./scripts/with-root-env.sh --mode production turbo build --parallel --filter !@school-clerk/jobs --filter  !@school-clerk/api --filter !@school-clerk/site",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:push": "bun --cwd packages/db push",
    "db:push:dev": "bun --cwd packages/db push:dev",
    "db:push:local": "bun --cwd packages/db push:local",
    "db:push:prod": "bun --cwd packages/db push:prod",
    "db:pull": "bun --cwd packages/db pull",
    "db:pull:dev": "bun --cwd packages/db pull:dev",
    "db:pull:local": "bun --cwd packages/db pull:local",
    "db:studio": "bun --cwd packages/db studio",
    "db:studio:dev": "bun --cwd packages/db studio:dev",
    "db:studio:local": "bun --cwd packages/db studio:local",
    "db:migrate": "bun --cwd packages/db db-migrate",
    "db:migrate:dev": "bun --cwd packages/db db-migrate:dev",
    "db:migrate:local": "bun --cwd packages/db db-migrate:local",
    "db:generate": "bun --cwd packages/db prisma-generate",
    "db:generate:dev": "bun --cwd packages/db prisma-generate:dev",
    "db:generate:local": "bun --cwd packages/db prisma-generate:local",
    "db:update:local": "bun --cwd packages/db sync:prod-to-local",
    "db:update:local:dry-run": "bun --cwd packages/db sync:prod-to-local:dry-run",
    "db:update:local:reset": "bun --cwd packages/db sync:prod-to-local --reset-cursor",
    "db:sync:prod-to-local": "bun --cwd packages/db sync:prod-to-local",
    "db:sync:prod-to-local:dry-run": "bun --cwd packages/db sync:prod-to-local:dry-run",
    "db:sync:prod-to-local:table": "bun --cwd packages/db sync:prod-to-local:table",
    "db:docker:up": "bun run dev:services:local",
    "db:docker:down": "docker compose -f docker-compose.yml down",
    "db:start": "bun run dev:services:local",
    "db:shell": "bun scripts/with-dev-infra.ts -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "db:shell:dev": "bun scripts/with-dev-infra.ts --db remote-dev -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "db:shell:local": "bun scripts/with-dev-infra.ts --db local -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "dev:prepare": "bun run kill:ports && bun run dev:services",
    "dev:services": "sh ./scripts/start-dev-services.sh",
    "dev:services:local": "SCHOOL_CLERK_DB_MODE=local SCHOOL_CLERK_START_POSTGRES=1 bun run dev:services",
    "dev:services:local-db": "SCHOOL_CLERK_DB_MODE=local SCHOOL_CLERK_START_POSTGRES=1 bun run dev:services",
    "dev": "bun scripts/with-dev-infra.ts -- bun run dev:run",
    "dev:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --parallel",
    "dev:local": "bun scripts/with-dev-infra.ts --db local -- bun run dev:run",
    "dev:remote-db": "bun scripts/with-dev-infra.ts --db remote-dev -- bun run dev:run",
    "dev:api": "bun scripts/with-dev-infra.ts -- bun run dev:api:run",
    "dev:api:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/api",
    "dev:dashboard": "bun scripts/with-dev-infra.ts -- bun run dev:dashboard:run",
    "dev:dashboard:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/dashboard",
    "dev:dashboard:full": "bun scripts/with-dev-infra.ts -- bun run dev:dashboard:full:run",
    "dev:dashboard:full:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/dashboard --filter=@school-clerk/api",
    "dev:site": "bun scripts/with-dev-infra.ts -- bun run dev:site:run",
    "dev:site:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/site",
    "dev:school-site": "bun scripts/with-dev-infra.ts -- bun run dev:school-site:run",
    "dev:school-site:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/school-site",
    "dev:websites": "bun scripts/with-dev-infra.ts -- bun run dev:websites:run",
    "dev:websites:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --filter=@school-clerk/dashboard --filter=@school-clerk/site --filter=@school-clerk/school-site --filter=@school-clerk/jobs",
    "jobs": "bun scripts/with-dev-infra.ts -- bun run jobs:run",
    "jobs:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --parallel --filter @school-clerk/jobs",
    "jobs:deploy": "bun run --filter @school-clerk/jobs deploy",
    "websites": "bun run dev:websites",
    "dashboard": "bun run dev:dashboard:full",
    "terminal": "bash ./scripts/open-bun-script-terminal.sh",
    "dev2": "bun scripts/with-dev-infra.ts -- bun run dev2:run",
    "dev2:run": "bun run dev:prepare && SCHOOL_CLERK_DEV_SERVICES_STARTED=1 turbo dev --parallel --filter !@school-clerk/jobs --filter  !@school-clerk/api --filter !@school-clerk/site",
    "format": "turbo format --continue -- --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "format:fix": "turbo format --continue -- --write --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "lint": "turbo lint -- --quiet -- --cache --cache-location 'node_modules/.cache/.eslintcache' && manypkg check",
    "kill:ports": "./scripts/with-root-env.sh --mode local sh ./scripts/kill-port.sh",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location 'node_modules/.cache/.eslintcache' ",
    "typecheck": "turbo typecheck",
    "--postinstall": "bun run check-deps",
    "check-deps": "check-dependency-version-consistency .",
    "gen": "turbo gen --config 'turbo/generators/config.ts'"
  },
  "dependencies": {
    "@biomejs/biome": "1.9.4",
    "@manypkg/cli": "^0.24.0",
    "turbo": "2.5.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@turbo/gen": "2.5.4",
    "@types/node": "^24.7.2",
    "check-dependency-version-consistency": "4.1.0",
    "knip": "^5.61.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.16"
}
