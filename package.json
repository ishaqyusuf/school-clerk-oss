{
  "name": "schoolclerk",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "tooling/*"
  ],
  "scripts": {
    "build": "./scripts/with-root-env.sh --mode production turbo build",
    "build:dashboard": "./scripts/with-root-env.sh --mode production turbo build --parallel --filter !@school-clerk/jobs --filter  !@school-clerk/api --filter !@school-clerk/marketing",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:push": "bun scripts/db-push.ts",
    "db:pull": "bun scripts/db-command.ts pull",
    "db:pull:dev": "bun scripts/db-command.ts pull --remote",
    "db:pull:local": "bun scripts/db-command.ts pull --local",
    "db:studio": "bun scripts/db-command.ts studio",
    "db:studio:dev": "bun scripts/db-command.ts studio --remote",
    "db:studio:local": "bun scripts/db-command.ts studio --local",
    "db:migrate": "bun scripts/db-command.ts migrate",
    "db:migrate:dev": "bun scripts/db-command.ts migrate --remote",
    "db:migrate:local": "bun scripts/db-command.ts migrate --local",
    "db:migrate:prod": "bun scripts/db-command.ts migrate --prod",
    "db:generate": "bun scripts/db-command.ts generate",
    "db:generate:dev": "bun scripts/db-command.ts generate --remote",
    "db:generate:local": "bun scripts/db-command.ts generate --local",
    "db:generate:prod": "bun scripts/db-command.ts generate --prod",
    "db:update:local": "bun run --cwd packages/db sync:prod-to-local",
    "db:update:local:dry-run": "bun run --cwd packages/db sync:prod-to-local:dry-run",
    "db:update:local:reset": "bun run --cwd packages/db sync:prod-to-local --reset-cursor",
    "db:sync:prod-to-local": "bun run --cwd packages/db sync:prod-to-local",
    "db:sync:prod-to-local:dry-run": "bun run --cwd packages/db sync:prod-to-local:dry-run",
    "db:sync:prod-to-local:table": "bun run --cwd packages/db sync:prod-to-local:table",
    "db:docker:up": "bun run dev:services:local",
    "db:docker:down": "docker compose -f docker-compose.yml down",
    "db:start": "bun run dev:services:local",
    "db:shell": "bun scripts/with-dev-infra.ts -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "db:shell:dev": "bun scripts/with-dev-infra.ts --db remote-dev -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "db:shell:local": "bun scripts/with-dev-infra.ts --db local -- sh -c 'exec psql \"$DATABASE_URL\"'",
    "dev:prepare": "bun run kill:ports && bun run dev:services",
    "dev:services": "sh ./scripts/start-dev-services.sh",
    "dev:services:local": "SCHOOL_CLERK_DB_MODE=local SCHOOL_CLERK_START_POSTGRES=1 bun run dev:services",
    "dev:services:local-db": "SCHOOL_CLERK_DB_MODE=local SCHOOL_CLERK_START_POSTGRES=1 bun run dev:services",
    "dev": "bun scripts/dev.ts",
    "jobs:deploy": "bun run --filter @school-clerk/jobs deploy",
    "terminal": "bash ./scripts/open-bun-script-terminal.sh",
    "format": "turbo format --continue -- --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "format:fix": "turbo format --continue -- --write --cache --cache-location='node_modules/.cache/.prettiercache' --ignore-path='../../.gitignore'",
    "lint": "turbo lint -- --quiet -- --cache --cache-location 'node_modules/.cache/.eslintcache' && manypkg check",
    "kill:ports": "./scripts/with-root-env.sh --mode local sh ./scripts/kill-port.sh",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location 'node_modules/.cache/.eslintcache' ",
    "typecheck": "turbo typecheck",
    "--postinstall": "bun run check-deps",
    "check-deps": "check-dependency-version-consistency .",
    "gen": "turbo gen --config 'turbo/generators/config.ts'"
  },
  "dependencies": {
    "@biomejs/biome": "1.9.4",
    "@manypkg/cli": "^0.24.0",
    "turbo": "2.5.6",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@turbo/gen": "2.5.4",
    "@types/node": "^24.7.2",
    "check-dependency-version-consistency": "4.1.0",
    "knip": "^5.61.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.16"
}
