{
  "name": "@school-clerk/school-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode local -- PORTLESS_WILDCARD=1 PORTLESS_PORT=${SCHOOL_CLERK_PORTLESS_PROXY_PORT:-443} PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-${SITE_PORT:-2400}} portless school-clerk-site next dev --turbopack",
    "build": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode prod -- sh -c 'bun --cwd ../../packages/db run prisma-generate:prod && next build --turbopack'",
    "start": "bun ../../../local-infra-kit/bin/with-env.ts --profile school-clerk --mode prod -- next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@school-clerk/auth": "workspace:*",
    "@school-clerk/db": "workspace:*",
    "@school-clerk/email": "workspace:*",
    "@school-clerk/pdf": "workspace:*",
    "@school-clerk/template-registry": "workspace:*",
    "@school-clerk/tenant-url": "workspace:*",
    "@school-clerk/tsconfig": "workspace:*",
    "@school-clerk/ui": "workspace:*",
    "@school-clerk/utils": "workspace:*",
    "@vercel/blob": "^2.3.3",
    "next": "^16.2.10",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.7.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
