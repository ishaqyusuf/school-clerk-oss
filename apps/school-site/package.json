{
  "name": "@school-clerk/school-site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "../../scripts/with-root-env.sh --mode local PORTLESS_WILDCARD=1 PORTLESS_HTTPS=0 PORTLESS_PORT=${PORTLESS_PORT:-1355} PORTLESS_APP_PORT=${PORTLESS_APP_PORT:-2400} portless school-clerk-site next dev --turbopack",
    "build": "../../scripts/with-root-env.sh --mode production sh -c 'SCHOOL_CLERK_ENV_MODE=production bun --cwd ../../packages/db prisma-generate && next build --turbopack'",
    "start": "../../scripts/with-root-env.sh --mode production next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@school-clerk/auth": "workspace:*",
    "@school-clerk/db": "workspace:*",
    "@school-clerk/email": "workspace:*",
    "@school-clerk/pdf": "workspace:*",
    "@school-clerk/template-registry": "workspace:*",
    "@school-clerk/tenant-url": "workspace:*",
    "@school-clerk/tsconfig": "workspace:*",
    "@school-clerk/ui": "workspace:*",
    "@school-clerk/utils": "workspace:*",
    "@vercel/blob": "^2.3.3",
    "next": "^16.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^24.7.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.5",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  }
}
