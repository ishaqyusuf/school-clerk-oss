# SchoolClerk root env example
# Local env uses .env.local.
# Remote development loads .env.remote.local over .env.local.
# Production uses .env.prod.

## Database
DATABASE_URL=

## Optional one-off sync overrides
SOURCE_DATABASE_URL=
TARGET_DATABASE_URL=

## Auth
BETTER_AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

## URLs
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ROOT_DOMAIN=
APP_ROOT_DOMAIN=

## Local Dev Ports
LEGACY_APP_PORT=2100
DASHBOARD_PORT=2200
MARKETING_PORT=2300
SITE_PORT=2400
API_PORT=2500

## Email and media
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
DEV_EMAIL_RECIPIENT=
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BLOB_READ_WRITE_TOKEN=

## Jobs
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

## Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
SCHOOL_CLERK_SCHOOL_SITE_VERCEL_PROJECT_ID=
SCHOOL_CLERK_DASHBOARD_VERCEL_PROJECT_ID=
