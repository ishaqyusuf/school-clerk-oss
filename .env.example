# SchoolClerk root env example
# Local env uses .env.local; production uses .env.production.

## Runtime mode
SCHOOL_CLERK_DB_MODE=remote-dev
SCHOOL_CLERK_START_POSTGRES=
SCHOOL_CLERK_ENV_MODE=

## Database
POSTGRES_URL=
DATABASE_URL=
DIRECT_URL=
REMOTE_DEV_POSTGRES_URL=
REMOTE_DEV_DATABASE_URL=
REMOTE_DEV_DIRECT_URL=
DEV_POSTGRES_URL=
DEV_DATABASE_URL=
DEV_DIRECT_URL=
LOCAL_POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:55432/school_clerk
LOCAL_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55432/school_clerk
LOCAL_DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:55432/school_clerk
PROD_POSTGRES_URL=
SOURCE_POSTGRES_URL=
PROD_DATABASE_URL=
SOURCE_DATABASE_URL=
TARGET_POSTGRES_URL=
TARGET_DATABASE_URL=

## Auth
BETTER_AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=

## URLs
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_ROOT_DOMAIN=
APP_ROOT_DOMAIN=

## Email and media
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
DEV_EMAIL_RECIPIENT=
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_BLOB_READ_WRITE_TOKEN=

## Jobs
TRIGGER_PROJECT_ID=
TRIGGER_SECRET_KEY=

## Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
SCHOOL_CLERK_SCHOOL_SITE_VERCEL_PROJECT_ID=
SCHOOL_CLERK_DASHBOARD_VERCEL_PROJECT_ID=
