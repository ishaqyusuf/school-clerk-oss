{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local", "**/.env.production"],
  "globalEnv": [
    "APP_ENV",
    "APP_ROOT_DOMAIN",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "DASHBOARD_APP_URL",
    "DATABASE_URL",
    "DEV_DATABASE_URL",
    "DEV_POSTGRES_URL",
    "DIRECT_URL",
    "LOCAL_DATABASE_URL",
    "LOCAL_POSTGRES_URL",
    "NODE_ENV",
    "POSTGRES_URL",
    "PROD_DATABASE_URL",
    "PROD_POSTGRES_URL",
    "REMOTE_DEV_DATABASE_URL",
    "REMOTE_DEV_POSTGRES_URL",
    "SCHOOL_CLERK_DB_MODE",
    "VERCEL",
    "VERCEL_ENV",
    "VERCEL_PROJECT_PRODUCTION_URL",
    "VERCEL_URL"
  ],
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "env": [
        "DATABASE_URL",
        "POSTGRES_URL",
        "DIRECT_URL",
        "REMOTE_DEV_DATABASE_URL",
        "REMOTE_DEV_POSTGRES_URL",
        "DEV_DATABASE_URL",
        "DEV_POSTGRES_URL",
        "LOCAL_DATABASE_URL",
        "LOCAL_POSTGRES_URL",
        "PROD_DATABASE_URL",
        "PROD_POSTGRES_URL",
        "SCHOOL_CLERK_DB_MODE",
        "APP_ENV",
        "NODE_ENV",
        "APP_ROOT_DOMAIN",
        "DASHBOARD_APP_URL",
        "BETTER_AUTH_URL",
        "VERCEL",
        "VERCEL_ENV",
        "VERCEL_URL",
        "VERCEL_PROJECT_PRODUCTION_URL",
        "BETTER_AUTH_SECRET"
      ],
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".expo/**",
        "dist/**",
        "src/generated/**",
        "build/**",
        "lib/**"
      ]
    },
    "prisma-generate": {
      "cache": false,
      "interactive": true
    },
    "db-generate": {
      "cache": false,
      "interactive": true
    },
    "db-migrate": {
      "cache": false,
      "interactive": true
    },
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false,
      "interactive": true
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "pull": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^generate"],
      "persistent": true,
      "env": [
        "DATABASE_URL",
        "POSTGRES_URL",
        "REMOTE_DEV_DATABASE_URL",
        "DEV_DATABASE_URL",
        "REMOTE_DEV_POSTGRES_URL",
        "DEV_POSTGRES_URL",
        "LOCAL_DATABASE_URL",
        "LOCAL_POSTGRES_URL",
        "SCHOOL_CLERK_DB_MODE",
        "SCHOOL_CLERK_START_POSTGRES"
      ],
      "cache": false
    },
    "dev:prod": {
      "dependsOn": ["^dev:prod"],
      "persistent": true,
      "cache": false
    },
    "format": {},
    "lint": {
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
