{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local", "**/.env.production"],
  "ui": "tui",
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "env": [
        "POSTGRES_URL",
        "DATABASE_URL",
        "DIRECT_URL",
        "REMOTE_DEV_POSTGRES_URL",
        "REMOTE_DEV_DATABASE_URL",
        "LOCAL_POSTGRES_URL",
        "SCHOOL_CLERK_DB_MODE",
        "BETTER_AUTH_SECRET"
      ],
      "dependsOn": ["^build"],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "next-env.d.ts",
        ".expo/**",
        "dist/**",
        "build/**",
        "lib/**"
      ]
    },
    "prisma-generate": {
      "cache": false,
      "interactive": true
    },
    "db-generate": {
      "cache": false,
      "interactive": true
    },
    "db-migrate": {
      "cache": false,
      "interactive": true
    },
    "generate": {
      "cache": false
    },
    "migrate": {
      "cache": false,
      "interactive": true
    },
    "push": {
      "cache": false,
      "interactive": true
    },
    "pull": {
      "cache": false,
      "interactive": true
    },
    "studio": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["^generate"],
      "persistent": true,
      "env": [
        "POSTGRES_URL",
        "DATABASE_URL",
        "DIRECT_URL",
        "REMOTE_DEV_POSTGRES_URL",
        "REMOTE_DEV_DATABASE_URL",
        "REMOTE_DEV_DIRECT_URL",
        "DEV_POSTGRES_URL",
        "DEV_DATABASE_URL",
        "DEV_DIRECT_URL",
        "LOCAL_POSTGRES_URL",
        "LOCAL_DATABASE_URL",
        "LOCAL_DIRECT_URL",
        "SCHOOL_CLERK_DB_MODE",
        "SCHOOL_CLERK_START_POSTGRES"
      ],
      "cache": false
    },
    "dev:prod": {
      "dependsOn": ["^dev:prod"],
      "persistent": true,
      "cache": false
    },
    "format": {},
    "lint": {
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
